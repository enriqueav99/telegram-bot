# Token del bot de Telegram (obligatorio)
# Obtenlo hablando con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# IDs de usuario de Telegram separados por comas (obligatorio)
# Obtén tu ID con @userinfobot en Telegram
ALLOWED_USERS=123456789,987654321

# Chat ID al que se envían las alertas de Alertmanager (opcional)
# Puede ser tu ID personal o el ID de un grupo
ALERTS_CHAT_ID=

# Puerto para recibir webhooks de Alertmanager (default: 9091)
ALERTS_PORT=9091

# Nivel de log: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
